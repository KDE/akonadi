#, kde-format
msgctxt "NAME OF TRANSLATORS"
msgid "Your names"
msgstr "Roman Paholík"

#, kde-format
msgctxt "EMAIL OF TRANSLATORS"
msgid "Your emails"
msgstr "wizzardsk@gmail.com"

#: dbmigrator.cpp:449
#, kde-format
msgctxt "@info:status"
msgid "Stopping Akonadi service..."
msgstr "Zastavuje sa služba Akonadi..."

#: dbmigrator.cpp:452
#, kde-format
msgctxt "@info:status"
msgid "Error: timeout while waiting for Akonadi to stop."
msgstr "Chyba: vypršal čas čakania na zastavenie Akonadi."

#: dbmigrator.cpp:459
#, kde-format
msgctxt "@info:status"
msgid "Error: couldn't acquire DBus lock for Akonadi."
msgstr "Chyba: nepodarilo sa získať zámok DBus pre Akonadi."

#: dbmigrator.cpp:468
#, kde-format
msgctxt "@info:status"
msgid "Starting Akonadi service..."
msgstr "Spúšťa sa služba Akonadi..."

#: dbmigrator.cpp:481
#, kde-format
msgctxt "@info:status"
msgid "Database fsck completed"
msgstr "Kontrola databázy (fsck) dokončená"

#: dbmigrator.cpp:495
#, kde-format
msgctxt "@info:status"
msgid ""
"Invalid database engine \"%1\" - valid values are \"sqlite\", \"mysql\" and "
"\"postgres\"."
msgstr ""
"Neplatný databázový engine \"%1\" - platné hodnoty sú \"sqlite\", \"mysql\" "
"a \"postgres\"."

#: dbmigrator.cpp:517
#, kde-format
msgctxt "@info:shell"
msgid "Error: failed to configure source database server."
msgstr "Chyba: nepodarilo sa nakonfigurovať zdrojový databázový server."

#: dbmigrator.cpp:522
#, kde-format
msgctxt "@info:shell"
msgid "Source and destination database engines are the same."
msgstr "Zdrojový a cieľový databázový engine sú rovnaké."

#: dbmigrator.cpp:529
#, kde-format
msgctxt "@info:shell"
msgid "Error: failed to obtain path to source database data file or directory."
msgstr ""
"Chyba: nepodarilo sa získať cestu k dátovému súboru alebo adresáru zdrojovej "
"databázy."

#: dbmigrator.cpp:536
#, kde-format
msgctxt "@info:shell"
msgid "Error: failed to configure the new database server."
msgstr "Chyba: nepodarilo sa nakonfigurovať nový databázový server."

#: dbmigrator.cpp:542
#, kde-format
msgctxt "@info:shell"
msgid "Error: failed to open existing database to migrate data from."
msgstr "Chyba: nepodarilo sa otvoriť existujúcu databázu na migráciu dát."

#: dbmigrator.cpp:547
#, kde-format
msgctxt "@info:shell"
msgid "Error: failed to open new database to migrate data to."
msgstr "Chyba: nepodarilo sa otvoriť novú databázu na migráciu dát."

#: dbmigrator.cpp:552
#, kde-format
msgctxt "@info:status"
msgid "Running fsck on the source database"
msgstr "Spúšťa sa kontrola (fsck) zdrojovej databázy"

#: dbmigrator.cpp:571
#, kde-format
msgctxt "@info:status %2 is error message"
msgid "Error: failed to remove temporary database directory %1: %2"
msgstr "Chyba: nepodarilo sa odstrániť dočasný adresár databázy %1: %2"

#: dbmigrator.cpp:578
#, kde-format
msgctxt "@info:shell"
msgid "Backing up original database..."
msgstr "Zálohovanie pôvodnej databázy..."

#: dbmigrator.cpp:586
#, kde-format
msgctxt "@info:status"
msgid "Restoring database from backup %1 to %2"
msgstr "Obnovenie databázy zo zálohy %1 do %2"

#: dbmigrator.cpp:588
#, kde-format
msgctxt "@info:status %1 is error message"
msgid "Error: failed to restore database from backup: %1"
msgstr "Chyba: nepodarilo sa obnoviť databázu zo zálohy: %1"

#: dbmigrator.cpp:620 dbmigrator.cpp:631
#, kde-format
msgctxt "@info:shell"
msgid "Error has occurred while migrating table %1"
msgstr "Nastala chyba pri migrácii tabuľky %1"

#: dbmigrator.cpp:650
#, kde-format
msgctxt "@label"
msgid ""
"Backup directory already exists. Do you want to overwrite the previous "
"backup?"
msgstr "Záložný adresár už existuje. Chcete prepísať predchádzajúcu zálohu?"

#: dbmigrator.cpp:655
#, kde-format
msgctxt "@info:shell"
msgid "Cannot proceed without backup. Migration interrupted."
msgstr "Nie je možné pokračovať bez zálohy. Migrácia bola prerušená."

#: dbmigrator.cpp:660
#, kde-format
msgctxt "@info:shell"
msgid "Failed to remove previous backup directory."
msgstr "Nepodarilo sa odstrániť predchádzajúci záložný adresár."

#: dbmigrator.cpp:673
#, kde-format
msgctxt "@info:shell"
msgid "Failed to move database to backup location: %1"
msgstr "Nepodarilo sa presunúť databázu na miesto zálohy: %1"

#: dbmigrator.cpp:687
#, kde-format
msgctxt "@label"
msgid "Backup file %1 already exists. Overwrite?"
msgstr "Záložný súbor %1 už existuje. Prepísať?"

#: dbmigrator.cpp:689
#, kde-format
msgctxt "@info:status"
msgid "Cannot proceed without backup. Migration interrupted."
msgstr "Nie je možné pokračovať bez zálohy. Migrácia bola prerušená."

#: dbmigrator.cpp:695
#, kde-format
msgctxt "@info:status"
msgid "Error: Failed to remove existing backup file %1: %2"
msgstr "Chyba: nepodarilo sa odstrániť existujúci záložný súbor %1: %2"

#: dbmigrator.cpp:702
#, kde-format
msgctxt "@info:status"
msgid "Failed to back up Akonadi Server configuration: %1"
msgstr "Nepodarilo sa zálohovať konfiguráciu servera Akonadi: %1"

#: dbmigrator.cpp:719
#, kde-format
msgctxt "@info:status %1 is error message"
msgid "Error: failed to move migrated database to the primary location: %1"
msgstr "Chyba: nepodarilo sa presunúť migrovanú databázu na hlavné miesto: %1"

#: dbmigrator.cpp:738
#, kde-format
msgctxt "@info:status %1 is error message"
msgid "Error: failed to remove original akonadiserverrc: %1"
msgstr "Chyba: nepodarilo sa odstrániť pôvodný súbor akonadiserverrc: %1"

#: dbmigrator.cpp:744
#, kde-format
msgctxt "@info:status %1 is error message"
msgid "Error: failed to move new akonadiserverrc to the primary location: %1"
msgstr ""
"Chyba: nepodarilo sa presunúť nový súbor akonadiserverrc na hlavné miesto: %1"

#: dbmigrator.cpp:835
#, kde-format
msgctxt "@info:status"
msgid "Error: failed to update autoincrement value for table %1"
msgstr ""
"Chyba: nepodarilo sa aktualizovať hodnotu automatického inkrementu pre "
"tabuľku %1"

#: dbmigrator.cpp:840
#, kde-format
msgctxt "@info:status"
msgid "Optimizing table %1..."
msgstr "Optimalizuje sa tabuľka %1..."

#: dbmigrator.cpp:843
#, kde-format
msgctxt "@info:status"
msgid "Error: failed to optimize table %1"
msgstr "Chyba: nepodarilo sa optimalizovať tabuľku %1"

#: main.cpp:31
#, kde-format
msgctxt ""
"Options for user to input to command line prompt, parenthesis indicate which "
"letter to type, capitalized option is default"
msgid " [(y)es/(N)o] "
msgstr " [(á)no/(N)ie] "

#: main.cpp:36 main.cpp:55
#, kde-format
msgctxt "Letter for option \"(y)es\" prompted from command line"
msgid "y"
msgstr "y"

#: main.cpp:49
#, kde-format
msgctxt ""
"Options for user to input to command line prompt, parenthesis indicate which "
"letter to type, capitalized option is default"
msgid " [(y)es/(N)o/(s)kip] "
msgstr " [(á)no/(N)ie/(p)reskoč] "

#: main.cpp:56
#, kde-format
msgctxt "Letter for option \"(s)kip\" prompted from command line"
msgid "s"
msgstr "s"

#: main.cpp:75 main.cpp:77
#, kde-format
msgid "Akonadi DB Migrator"
msgstr "Migrátor databázy Akonadi"

#: main.cpp:79
#, kde-format
msgid "(c) 2024 g10 Code GmbH"
msgstr "(c) 2024 g10 Code GmbH"

#: main.cpp:85
#, kde-format
msgid ""
"The new DB engine to use. Possible values are  \"sqlite\", \"mysql\" and "
"\"postgres\""
msgstr ""
"Nový databázový engine na použitie. Možné hodnoty sú \"sqlite\", \"mysql\" a "
"\"postgres\""

#: main.cpp:92
#, kde-format
msgctxt "@info:shell"
msgid "Invalid target engine: %1."
msgstr "Neplatný cieľový engine: %1."

#: main.cpp:106
#, kde-format
msgctxt "@info:status"
msgid "Migration completed successfully."
msgstr "Migrácia bola úspešne dokončená."

#: main.cpp:108
#, kde-format
msgctxt "@info:status"
msgid "Migration failed."
msgstr "Migrácia zlyhala."

#: main.cpp:113
#, kde-format
msgctxt "@info:progress"
msgid "Migrating table %1 (%2/%3)..."
msgstr "Migruje sa tabuľka %1 (%2/%3)..."

#: main.cpp:127
#, kde-format
msgctxt "@info:progress"
msgid "%1%..."
msgstr "%1%..."
